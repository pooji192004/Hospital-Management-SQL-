#relationship tables
create table consults ( P_ID int,
						D_ID int,
                        Consult_Date date,
                        primary key (P_ID,D_ID,Consult_Date),
                        foreign key (P_ID) references patients (P_ID),
                        foreign key (D_ID) references doctors (D_ID));
select * from consults;
