use hospital;

create table Assigned ( P_ID int,
						R_ID int,
                        primary key (P_ID,R_ID),
                        foreign key (P_ID) references patients(P_ID),
                        foreign key (R_ID) references rooms (R_ID));
select * from assigned;
insert into assigned values (1,301);
insert into assigned values (2,302);
insert into assigned values (3,303);

use hospital;

create table pays ( P_ID int,
					B_ID int,
                    primary key (P_ID,B_ID),
                    foreign key (P_ID) references patients(P_ID),
                    foreign key (B_ID) references bills (B_ID));
select * from pays;
