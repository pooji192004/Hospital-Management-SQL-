#triggers
#1.bills table: before insert
use hospital;
delimiter //
create trigger bill_results
before insert
on bills
for each row
begin
if new.amount > 0 then
signal sqlstate'45000'
set message_text= "Bill amount cannot be negative";
end if;
end;

#2.testreport table:after insert
use hospital;
create table test_report_log(TR_ID int primary key,
                              P_ID int,
                              R_ID int,
                              Test_Type varchar(50),
                              Result varchar(50));
	select* from test_report_log;
    alter table test_report_log
    add entrytime time;
    
    delimiter //
    create trigger test_report_details
    after insert
    on test_report
    for each row
    begin
    insert into test_report_log values (new.TR_ID,new.P_ID,new.R_ID,new.Test_Type,new.Result,now());
    end;
    select* from test_report_log;
    insert into test_report values (411,1,301,"MRI","Normal");
    
    #3.1.bills table:before update
    use hospital;
    delimiter //
    create trigger before_update_bills
    before update
    on bills
    for each row
    begin
	if new.amount < 0 then
    signal sqlstate'45000'
set message_text= "Bill amount cannot be negative";
end if;
end;

#2.rooms table
 use hospital;
    delimiter //
    create trigger before_update_rooms
    before update
    on rooms
    for each row
    begin
	if new.R_capacity <= 0 then
    signal sqlstate'45000'
set message_text= "Room capacity must be greater than zero";
end if;
end;

#4.bills:after update
use hospital;
create table bills_update(B_ID int primary key,
                          old_amount int,
                          new_amount int,
                          updated_on time);
	select * from bills_update;
    insert into bills_update values (401,2000,3000,now());
    
    delimiter //
    create trigger bills_history
    after update
    on bills
    for each row 
    begin
    if old.amount<> new.amount then
    insert into bills_update values(old.B_ID,OLD.amount,new.amount,now());
    end if;
    end;
    
    #5.before delete-back up patient data
     use hospital;
     create table patient_backup(P_ID int primary key,
                                 P_Name varchar(20),
                                 P_Gender varchar(10),
                                 P_Age int,
                                 P_Mobileno varchar(10),
                                 P_DOB date);
	select * from patient_backup;
    alter table patient_backup
    add backup_time varchar (100);
    
    delimiter //
    create trigger before_delete_patient
    before delete 
    on patients 
    for each row
    begin
    insert into patient_backup values (old.P_ID,old.P_Name,old.P_Gender,old.P_Age,old.P_Mobileno,old.P_DOB,now());
    end;
    
    #2back_up records data
     use hospital;
     create table records_backup(Record_No int primary key,
								 App_No int,
                                 Backup_update varchar(100));
		select * from records_backup;
        
        delimiter //
        create trigger before_delete_records
        before delete
        on records
        for each row
        begin
        insert into records_backup values(old.Record_No,old.App_No,now());
        end;
        
        #6. bills table:after delete
        use hospital;
        create table bills_delete_log(B_ID int primary key,
                                      P_ID int,
                                      amount int,
                                      deleted_on int);
		select * from bills_delete_log;
        
        delimiter //
        create trigger after_delete_patient
        after delete 
        on bills 
        for each row
        begin
        insert into bills_delete_log values(old.B_ID,old.P_ID,old.amount,now());
        end;
        
        call patient_details;
        
        call bills_details;
        call rooms_details;
        call records_details;
        call doctors_details;